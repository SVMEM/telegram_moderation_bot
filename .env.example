BOT_TOKEN=123456:replace-with-token-from-botfather
BOT_OWNER_IDS=123456789
BOT_DATABASE_PATH=data/bot.sqlite3
BOT_DEFAULT_MODE=test
STORE_MESSAGE_TEXT=true
LOG_RETENTION_DAYS=30

# Crypto Pay via @CryptoBot. Create token in Crypto Pay -> Create App.
CRYPTO_PAY_API_TOKEN=
CRYPTO_PAY_TESTNET=false
SUBSCRIPTION_REQUIRED=true
SUBSCRIPTION_BYPASS_OWNER=true
SUBSCRIPTION_PRICE=10.00
SUBSCRIPTION_FIAT=USD
SUBSCRIPTION_ACCEPTED_ASSETS=USDT,TON,BTC,ETH,LTC,BNB,TRX,USDC
SUBSCRIPTION_DAYS=30
SUBSCRIPTION_INVOICE_EXPIRES_SECONDS=86400
SUBSCRIPTION_CHECK_INTERVAL_SECONDS=60

# Local ML spam classifier.
ML_ENABLED=true
ML_MODEL_PATH=data/ml/spam_model.joblib
ML_SPAM_THRESHOLD=0.55
ML_ACTION=delete
ML_MIN_TEXT_LENGTH=8
